# FMS Automation Environment Variables

# Application
FMS_DEBUG=false
FMS_HOST=0.0.0.0
FMS_PORT=8000

# Paths
FMS_UPLOAD_DIR=/app/data/uploads
FMS_MODELS_DIR=/app/models

# Redis
FMS_REDIS_URL=redis://redis:6379/0

# Processing
FMS_MAX_VIDEO_SIZE_MB=500
FMS_VIDEO_FPS_TARGET=30
FMS_MAX_VIDEO_DURATION_SEC=600

# Pose Estimation
FMS_POSE_MODEL_COMPLEXITY=2
FMS_MIN_DETECTION_CONFIDENCE=0.5
FMS_MIN_TRACKING_CONFIDENCE=0.5

# LLM Integration
FMS_ENABLE_LLM_REPORTS=true
FMS_ENABLE_LLM_COACHING=true
FMS_ENABLE_LLM_ANALYSIS=true

# LLM API Keys (set the ones you want to use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Local Models (Ollama)
FMS_OLLAMA_URL=http://localhost:11434

# LLM Model Preferences (model IDs)
# Fast models: gpt-4o-mini, claude-3-5-haiku-20241022, gemini-2.0-flash, llama3.2, mistral
# Standard models: claude-sonnet-4-20250514, gemini-1.5-pro, llama3.1:70b
# Premium models: gpt-4o, claude-opus-4-20250514
FMS_LLM_REALTIME_MODEL=gpt-4o-mini
FMS_LLM_ANALYSIS_MODEL=claude-sonnet-4-20250514
FMS_LLM_REPORT_MODEL=claude-sonnet-4-20250514
FMS_LLM_FALLBACK_MODEL=gpt-3.5-turbo

# LLM Performance Settings
FMS_LLM_CACHE_ENABLED=true
FMS_LLM_CACHE_TTL=3600
FMS_LLM_REALTIME_TIMEOUT=3.0
FMS_LLM_ANALYSIS_TIMEOUT=30.0
FMS_LLM_REPORT_TIMEOUT=60.0

# CORS (comma-separated)
FMS_CORS_ORIGINS=*
